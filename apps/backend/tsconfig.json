{
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "outDir": "dist",
    "rootDir": "src",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "paths": {
      "@social-app/shared": ["../../packages/shared/src/index.ts"],
      "@social-app/shared/*": ["../../packages/shared/src/*"]
    }
  },
  "include": ["src/**/*"]
}
